+use sysinfo::{System, SystemExt};
+use std::time::Duration;
+use std::thread;
+use std::env;
+
+pub fn start_metrics_collector() {
+    thread::spawn(|| {
+        let mut sys = System::new_all();
+        let server_url = env::var("METRICS_URL").unwrap_or_else(|_| "http://127.0.0.1:21121/api/metrics".to_string());
+        loop {
+            sys.refresh_all();
+            let cpu_usage = sys.global_cpu_info().cpu_usage();
+            let total_memory = sys.total_memory();
+            let used_memory = sys.used_memory();
+            let total_disk = sys.total_disk_space();
+            let used_disk = sys.used_disk_space();
+            let data = serde_json::json!({
+                "cpu": cpu_usage,
+                "ram_used": used_memory,
+                "ram_total": total_memory,
+                "disk_used": used_disk,
+                "disk_total": total_disk,
+                "timestamp": chrono::Utc::now().timestamp(),
+            });
+            if let Err(e) = send_metrics(&server_url, &data) {
+                eprintln!("Failed to send metrics: {}", e);
+            }
+            thread::sleep(Duration::from_secs(10));
+        }
+    });
+}
+
+fn send_metrics(url: &str, data: &serde_json::Value) -> Result<(), Box<dyn std::error::Error>> {
+    let client = reqwest::blocking::Client::new();
+    client.post(url).json(data).send()?;
+    Ok(())
+}
